#!/bin/bash
# ===================================================================================
# ImmortalWrt 智能安装脚本
#
# 功能:
# 1. 交互式选择目标磁盘。
# 2. 自动创建 GPT 分区表 (EFI + ext4 主分区)。
# 3. 将 /mnt/immortalwrt.img 镜像内容写入主分区。
# 4. 安装 GRUB EFI 引导加载器，确保系统可从硬盘启动。
# 5. 提供多重安全检查，防止误操作。
#
# 作者: Gemini
# ===================================================================================

set -e # 任何命令失败则立即退出

# --- 配置与常量 ---
SRC_IMG="/mnt/immortalwrt.img"
MOUNT_POINT="/tmp/install_mnt"

# --- 函数定义 ---

# 打印高亮消息
function print_info() {
    echo -e "\033[1;34m[INFO] $1\033[0m"
}

function print_success() {
    echo -e "\033[1;32m[SUCCESS] $1\033[0m"
}

function print_warning() {
    echo -e "\033[1;33m[WARNING] $1\033[0m"
}

function print_error() {
    echo -e "\033[1;31m[ERROR] $1\033[0m" >&2
}

# --- 主程序开始 ---

print_info "欢迎使用 ImmortalWrt 智能安装脚本。"

# 1. 检查源镜像文件是否存在
if [ ! -f "$SRC_IMG" ]; then
    print_error "安装失败：未在 $SRC_IMG 找到源镜像文件。"
    print_error "请确保构建脚本已将 immortalwrt.img 正确放置到 /mnt/ 目录下。"
    exit 1
fi
print_info "检测到源镜像文件: $SRC_IMG"

# 2. 选择目标磁盘
print_info "正在检测可用磁盘..."
lsblk -d -o NAME,SIZE,MODEL
echo ""
read -p "请输入您要安装 ImmortalWrt 的目标磁盘名称 (例如: sda, nvme0n1, mmcblk0): " TARGET_DISK

# 检查输入是否为空
if [ -z "$TARGET_DISK" ]; then
    print_error "未输入磁盘名称，安装已取消。"
    exit 1
fi

TARGET_DEVICE="/dev/${TARGET_DISK}"

# 检查设备是否存在
if [ ! -b "$TARGET_DEVICE" ]; then
    print_error "设备 $TARGET_DEVICE 不存在，请检查您输入的名称是否正确。"
    exit 1
fi

# 3. 安全确认
print_warning "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! 警告 !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
print_warning "接下来的操作将完全擦除磁盘 '$TARGET_DEVICE' 上的所有数据。"
print_warning "此操作不可逆！请在继续前备份所有重要数据。"
print_warning "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
read -p "如果您确定要继续，请输入 'YES': " CONFIRMATION

if [ "$CONFIRMATION" != "YES" ]; then
    print_info "安装已取消。"
    exit 0
fi

print_info "用户已确认，开始在 $TARGET_DEVICE 上安装 ImmortalWrt..."

# 4. 卸载可能已挂载的分区
print_info "正在卸载目标磁盘上的所有分区..."
umount ${TARGET_DEVICE}* 2>/dev/null || true

# 5. 创建分区表和分区
print_info "正在创建 GPT 分区表和分区..."
parted --script "${TARGET_DEVICE}" -- \
    mklabel gpt \
    mkpart "EFI System Partition" fat32 1MiB 513MiB \
    set 1 esp on \
    mkpart "rootfs" ext4 513MiB 100%

# 等待内核识别新分区
partprobe "${TARGET_DEVICE}"
sleep 2

# 确定分区设备名称 (处理 sda1 vs mmcblk0p1 的差异)
if [[ "$TARGET_DISK" == "nvme"* || "$TARGET_DISK" == "mmcblk"* ]]; then
    EFI_PART="${TARGET_DEVICE}p1"
    ROOT_PART="${TARGET_DEVICE}p2"
else
    EFI_PART="${TARGET_DEVICE}1"
    ROOT_PART="${TARGET_DEVICE}2"
fi

print_info "EFI 分区: $EFI_PART"
print_info "根分区: $ROOT_PART"

# 6. 格式化分区
print_info "正在格式化分区..."
mkfs.vfat -F 32 "${EFI_PART}"
mkfs.ext4 -F "${ROOT_PART}"

# 7. 写入镜像文件
print_info "正在将 $SRC_IMG 写入到 $ROOT_PART..."
dd if="$SRC_IMG" of="$ROOT_PART" bs=4M status=progress

# 8. 安装引导加载器 (GRUB)
print_info "正在安装 GRUB EFI 引导加载器..."
mkdir -p "${MOUNT_POINT}"
mount "${ROOT_PART}" "${MOUNT_POINT}"
mkdir -p "${MOUNT_POINT}/boot/efi"
mount "${EFI_PART}" "${MOUNT_POINT}/boot/efi"

# 使用 --removable 选项可以提高兼容性
grub-install --target=x86_64-efi --boot-directory="${MOUNT_POINT}/boot" --efi-directory="${MOUNT_POINT}/boot/efi" --removable

# 9. 创建 GRUB 配置文件
print_info "正在生成 GRUB 配置文件 (grub.cfg)..."
# 通过 blkid 获取新根分区的 UUID，这是最可靠的方式
ROOT_UUID=$(blkid -s UUID -o value "${ROOT_PART}")
print_info "检测到根分区的 UUID 为: $ROOT_UUID"

# 创建 grub.cfg
cat <<EOF > "${MOUNT_POINT}/boot/grub/grub.cfg"
set timeout=3
set default=0

menuentry "ImmortalWrt" {
    search --no-floppy --fs-uuid --set=root ${ROOT_UUID}
    linux /boot/vmlinuz root=UUID=${ROOT_UUID} rootwait console=tty0 console=ttyS0,115200n8 quiet
    initrd /boot/initrd.img
}
EOF

print_info "grub.cfg 文件内容:"
cat "${MOUNT_POINT}/boot/grub/grub.cfg"

# 10. 清理
print_info "正在卸载分区..."
umount "${MOUNT_POINT}/boot/efi"
umount "${MOUNT_POINT}"
rmdir "${MOUNT_POINT}"

print_success "****************************************************************"
print_success "ImmortalWrt 安装成功!"
print_success "请移除安装介质，然后重启您的计算机。"
print_success "****************************************************************"

exit 0
